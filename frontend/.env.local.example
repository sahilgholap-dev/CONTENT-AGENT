# Frontend environment (copy to `.env.local` for local dev). All three are
# NEXT_PUBLIC_* so they are inlined into the browser bundle at build time.

# The FastAPI backend. Local dev: http://localhost:8000. Prod: the Render URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project (Project Settings -> API).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
