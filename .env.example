# Backend environment variables. Copy to `.env` for local dev; in production set
# these in the Render dashboard (never commit real secrets). `.env` is gitignored.

# --- Database (Supabase Postgres) ---
# Supabase -> Project Settings -> Database -> Connection string (URI).
# Use the :5432 direct string, or the :6543 transaction pooler for many clients.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# DB_POOL_MAX=5

# --- Auth (Supabase) ---
# Project URL (Supabase -> Project Settings -> API -> "Project URL"). Used to
# fetch the JWKS for the new asymmetric signing keys (ES256/RS256). REQUIRED.
SUPABASE_URL=https://<project-ref>.supabase.co
# Legacy HS256 secret (Project Settings -> API -> JWT Settings -> "JWT Secret").
# Only needed if your project still issues HS256 tokens; harmless to leave unset
# once you've moved to asymmetric signing keys.
# SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
# SUPABASE_JWT_AUD=authenticated
# Local dev ONLY: set to 1 to bypass token verification. NEVER set in production.
# AUTH_DISABLED=0

# --- CORS ---
# The frontend origin(s) allowed to call this API (comma-separated). e.g.
# https://your-app.web.app,http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# --- LLM / tools (unchanged from the prototype) ---
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OPENAI_API_KEY=<your-openai-api-key>
EXA_API_KEY=<your-exa-api-key>

# --- Optional image-generation settings ---
# IMAGE_MODEL=gpt-image-1
# IMAGE_SIZE=1024x1024
# GENERATE_IMAGES=1
