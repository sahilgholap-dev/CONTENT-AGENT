# Backend environment variables. Copy to `.env` for local dev; in production set
# these in the host (Railway) dashboard. This file is a COMMITTED TEMPLATE — it
# must contain placeholders only, never real secrets.

# --- Database (Supabase Postgres) ---
# Use the CONNECTION POOLER (IPv4). The direct host (db.<ref>.supabase.co) is
# IPv6-only and unreachable from many hosts (e.g. Railway), which crashes the
# app on startup. Get this from Supabase -> Project Settings -> Database ->
# Connection Pooling (Transaction mode, port 6543). Username is
# postgres.<project-ref>; percent-encode special chars in the password (@ -> %40).
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Direct connection (IPv6-only; works from some local networks, NOT from Railway):
# DATABASE_URL=postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres
# DB_POOL_MAX=5

# --- Auth (Supabase) ---
# Project URL (Supabase -> Project Settings -> API -> "Project URL"). Used to
# fetch the JWKS for the new asymmetric signing keys (ES256/RS256). REQUIRED.
SUPABASE_URL=https://<project-ref>.supabase.co
# Legacy HS256 secret (Project Settings -> API -> JWT Settings -> "JWT Secret").
# Only needed if your project still issues HS256 tokens; harmless to leave unset
# once you've moved to asymmetric signing keys.
# SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
# SUPABASE_JWT_AUD=authenticated
# Local dev ONLY: set to 1 to bypass token verification. NEVER set in production.
# AUTH_DISABLED=0

# --- CORS ---
# The frontend origin(s) allowed to call this API (comma-separated). e.g.
# https://your-app.web.app,http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# --- LLM / tools ---
ANTHROPIC_API_KEY=<your-anthropic-api-key>
OPENAI_API_KEY=<your-openai-api-key>
EXA_API_KEY=<your-exa-api-key>

# --- Optional image-generation settings ---
# IMAGE_MODEL=gpt-image-1
# IMAGE_SIZE=1024x1024
# GENERATE_IMAGES=1
